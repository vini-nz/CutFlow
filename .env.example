# Copie este arquivo para .env e ajuste os valores antes de subir o docker-compose.
# O .env nunca deve ser commitado no Git (já está no .gitignore).

# ---- Banco ----
DB_NAME=cutflow
DB_USER=cutflow
DB_PASSWORD=cutflow

# ---- Frontend ----
VITE_API_URL=http://localhost:8080/api/v1

# ---- Backend: CORS e URL do frontend (ADR-0005) ----
# Origem(ns) do frontend permitida(s), separadas por vírgula. Em produção,
# troque para o domínio real (ex.: https://cutflow.suamarcenaria.com.br).
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ---- Sessão / cookies (produção com HTTPS) ----
# Em produção, com HTTPS, defina SESSION_COOKIE_SECURE=true. Se o frontend e o
# backend ficarem em DOMÍNIOS diferentes, use também SESSION_COOKIE_SAMESITE=none.
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# ---- Login Google (opcional) ----
# Deixe em branco para desabilitar o login Google (só login local funciona).
# Crie as credenciais em https://console.cloud.google.com/ (OAuth 2.0 Client ID,
# tipo "Web application") e cadastre o redirect URI:
#   http://localhost:8080/login/oauth2/code/google   (dev)
#   https://SEU-BACKEND/login/oauth2/code/google      (produção)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
