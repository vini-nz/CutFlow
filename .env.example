# Copie este arquivo para .env e ajuste os valores antes de subir o docker-compose.
# O .env nunca deve ser commitado no Git (já está no .gitignore).
#
# Este arquivo cobre os dois cenários:
#   - Desenvolvimento local (docker-compose.yml)
#   - Produção (docker-compose.prod.yml) - guia completo em docs/deploy.md

# ---- Banco ----
DB_NAME=cutflow
DB_USER=cutflow
DB_PASSWORD=cutflow

# ---- Frontend (só usado em dev - docker-compose.yml) ----
VITE_API_URL=/api/v1

# ---- Backend: CORS e URL do frontend (ADR-0005) ----
# Origem(ns) do frontend permitida(s), separadas por vírgula.
#   Dev:  http://localhost:5173
#   Prod: https://app.seudominio.com  (o domínio real, com https://)
CORS_ALLOWED_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# ---- Domínio (só usado em produção - docker-compose.prod.yml) ----
# O serviço "edge" (Caddy) usa isso para servir o site e emitir HTTPS
# automaticamente via Let's Encrypt. Precisa ser um domínio que já aponta
# (DNS) para o IP público do servidor - ver docs/deploy.md.
#   Prod:            DOMAIN=app.seudominio.com
#   Teste local:      DOMAIN=:80   (HTTP simples, sem certificado)
DOMAIN=:80

# ---- Sessão / cookies ----
# Em produção (HTTPS obrigatório), defina SESSION_COOKIE_SECURE=true - é o
# padrão em docker-compose.prod.yml. Em dev local (HTTP), deixe "false".
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

# ---- Login Google (opcional) ----
# Deixe em branco para desabilitar o login Google (só login local funciona).
# Crie as credenciais em https://console.cloud.google.com/ (OAuth 2.0 Client ID,
# tipo "Web application") e cadastre o "Authorized redirect URI" EXATO:
#   Dev:  http://localhost:5173/login/oauth2/code/google
#   Prod: https://app.seudominio.com/login/oauth2/code/google
#
# Repare que em dev é a porta do FRONTEND (5173), não a do backend (8080) -
# o Vite faz proxy de /login/oauth2/* para o backend (ver vite.config.js),
# então o navegador e o Google só enxergam a origem :5173.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
